# ═══════════════════════════════════════════════════════════════════════════════
#  Stock Screener — Environment Variables Template
#  Copy this file to .env and fill in the values.
#     cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URL=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ── API Keys ─────────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stockscans ───────────────────────────────────────────────────────────────
STOCKSCANS_AUTH_TOKEN=

# ── Email (Gmail) ────────────────────────────────────────────────────────────
GMAIL_USERNAME=
GMAIL_PASSWORD=
GOOGLE_APP_PASSWORD=              # Gmail App Password (for cowork-jobs email service)

# ── Google Drive API (cowork-jobs) ───────────────────────────────────────────
# Generated by: yarn cowork:data:auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Twitter / X.com GraphQL session (Tweet Downloader) ───────────────────────
# Required: logged-in session cookies from browser DevTools (see docs/API_REFERENCE.md#x-twitter-apis)
TWITTER_AUTH_TOKEN=
TWITTER_CSRF_TOKEN=
# Optional: full Cookie header from a working x.com request (overrides auth_token + ct0 above)
TWITTER_COOKIES=
# Optional: defaults to x.com public web bearer if unset
TWITTER_BEARER_TOKEN=
# Optional: UserTweets query id from Network tab (default matches current web client)
TWITTER_USER_TWEETS_QUERY_ID=
# Required for handle lookup: UserByScreenName query id from Network tab when opening a profile
TWITTER_USER_BY_SCREEN_NAME_QUERY_ID=
# Optional: browser user-agent string copied from DevTools
TWITTER_USER_AGENT=

# ═══════════════════════════════════════════════════════════════════════════════
#  Optional Overrides (uncomment as needed)
# ═══════════════════════════════════════════════════════════════════════════════
# RESEARCH_ROOT=                    # Path to research workspace (default: ~/Research)
# STOCKMARKET_BACKEND=              # Backend URL for Python skills (default: http://localhost:5000)
# COWORK_DATA_DIR=                  # Cowork-jobs data directory override
# COWORK_DRIVE_ROOT=                # Google Drive folder ID for data sync
# COWORK_DRIVE_EMAIL=               # Google Drive owner email
# COWORK_DRIVE_SYNC=                # Set to 0 to disable Drive sync
