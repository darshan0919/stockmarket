# Frontend Development Rules

## Directory Structure

```
frontend/
├── components/       # React components
│   ├── common/      # Reusable components
│   ├── dashboard/   # Dashboard widgets
│   ├── screener/    # Screener components
│   └── stock/       # Stock detail components
├── lib/             # Utilities and hooks
│   ├── api.js       # API client
│   ├── hooks/       # Custom React hooks
│   └── utils/       # Helper functions
├── pages/           # Next.js pages
├── public/          # Static assets
└── styles/          # CSS styles
```

## Adding New Components

### Component Template

```javascript
// frontend/components/category/NewComponent.js
import { useState, useEffect } from 'react';

/**
 * NewComponent - Brief description
 * 
 * @param {Object} props
 * @param {string} props.requiredProp - Description
 * @param {string} [props.optionalProp] - Description
 * @returns {JSX.Element}
 * 
 * @example
 * <NewComponent requiredProp="value" />
 * 
 * @see {@link docs/frontend/components/NewComponent.md} for documentation
 */
export default function NewComponent({ requiredProp, optionalProp = 'default' }) {
  const [state, setState] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  useEffect(() => {
    // Effect logic
  }, []);

  if (loading) return <div>Loading...</div>;
  if (error) return <div>Error: {error}</div>;

  return (
    <div className="p-4 bg-white rounded-lg shadow">
      {/* Component content */}
    </div>
  );
}
```

